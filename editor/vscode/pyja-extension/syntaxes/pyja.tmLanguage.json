{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "PyJa",
    "scopeName": "source.pyja",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#characters" },
        { "include": "#annotations" },
        { "include": "#keywords-control" },
        { "include": "#keywords-modifier" },
        { "include": "#keywords-type" },
        { "include": "#keywords-other" },
        { "include": "#constants" },
        { "include": "#numbers" },
        { "include": "#operators" },
        { "include": "#class-declaration" },
        { "include": "#method-call" },
        { "include": "#identifiers" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.pyja",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.pyja",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.pyja",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.pyja",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "characters": {
            "patterns": [
                {
                    "name": "string.quoted.single.pyja",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "name": "constant.character.escape.pyja",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "annotations": {
            "patterns": [
                {
                    "name": "storage.type.annotation.pyja",
                    "match": "@\\w+"
                }
            ]
        },
        "keywords-control": {
            "patterns": [
                {
                    "name": "keyword.control.pyja",
                    "match": "\\b(if|else|for|while|do|switch|case|default|break|continue|return|throw|try|catch|finally|assert|yield)\\b"
                },
                {
                    "name": "keyword.control.import.pyja",
                    "match": "\\b(import|package)\\b"
                },
                {
                    "name": "keyword.control.new.pyja",
                    "match": "\\b(new|instanceof)\\b"
                }
            ]
        },
        "keywords-modifier": {
            "patterns": [
                {
                    "name": "storage.modifier.pyja",
                    "match": "\\b(public|private|protected|static|final|abstract|synchronized|volatile|transient|native|strictfp|default)\\b"
                }
            ]
        },
        "keywords-type": {
            "patterns": [
                {
                    "name": "storage.type.pyja",
                    "match": "\\b(class|interface|enum|extends|implements|throws)\\b"
                },
                {
                    "name": "storage.type.primitive.pyja",
                    "match": "\\b(void|int|long|float|double|boolean|char|byte|short|var)\\b"
                }
            ]
        },
        "keywords-other": {
            "patterns": [
                {
                    "name": "variable.language.pyja",
                    "match": "\\b(this|super)\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.pyja",
                    "match": "\\b(true|false|null)\\b"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.hex.pyja",
                    "match": "\\b0[xX][0-9a-fA-F_]+[lLfFdD]?\\b"
                },
                {
                    "name": "constant.numeric.binary.pyja",
                    "match": "\\b0[bB][01_]+[lL]?\\b"
                },
                {
                    "name": "constant.numeric.decimal.pyja",
                    "match": "\\b[0-9][0-9_]*(\\.[0-9][0-9_]*)?([eE][+-]?[0-9]+)?[lLfFdD]?\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.comparison.pyja",
                    "match": "(==|!=|<=|>=|<|>)"
                },
                {
                    "name": "keyword.operator.assignment.pyja",
                    "match": "(=|\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>=|>>>=)"
                },
                {
                    "name": "keyword.operator.arithmetic.pyja",
                    "match": "(\\+\\+|--|\\+|-|\\*|/|%)"
                },
                {
                    "name": "keyword.operator.logical.pyja",
                    "match": "(&&|\\|\\||!)"
                },
                {
                    "name": "keyword.operator.bitwise.pyja",
                    "match": "(&|\\||\\^|~|<<|>>|>>>)"
                },
                {
                    "name": "keyword.operator.ternary.pyja",
                    "match": "(\\?|:)"
                },
                {
                    "name": "keyword.operator.arrow.pyja",
                    "match": "->"
                }
            ]
        },
        "class-declaration": {
            "patterns": [
                {
                    "match": "\\b(class|interface|enum)\\s+([A-Z]\\w*)",
                    "captures": {
                        "1": { "name": "storage.type.pyja" },
                        "2": { "name": "entity.name.type.class.pyja" }
                    }
                }
            ]
        },
        "method-call": {
            "patterns": [
                {
                    "match": "\\b([a-zA-Z_]\\w*)\\s*(?=\\()",
                    "captures": {
                        "1": { "name": "entity.name.function.pyja" }
                    }
                }
            ]
        },
        "identifiers": {
            "patterns": [
                {
                    "name": "entity.name.type.pyja",
                    "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
                }
            ]
        }
    }
}
